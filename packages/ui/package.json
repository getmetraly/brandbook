{
  "name": "@metraly/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles/*.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/useRovingSelection": "./src/components/useRovingSelection.ts",
    "./styles/*": "./src/styles/*",
    "./source/*": "./src/source/*.tsx",
    "./settings/*": "./src/settings/*.tsx",
    "./charts": "./src/charts/index.ts",
    "./dashboard": "./src/dashboard/WidgetRegistry.ts",
    "./dashboard/types": "./src/dashboard/types.ts",
    "./dashboard/DashboardGrid": "./src/dashboard/DashboardGrid.tsx",
    "./dashboard/DashboardWidget": "./src/dashboard/DashboardWidget.tsx",
    "./dashboard/DashboardWidgetExamples": "./src/dashboard/DashboardWidgetExamples.tsx",
    "./dashboard/DashboardWizardSplitBuilder": "./src/dashboard/DashboardWizardSplitBuilder.tsx",
    "./dashboard/MoveMenuA11yExample": "./src/dashboard/MoveMenuA11yExample.tsx",
    "./dashboard/DashboardToolbar": "./src/dashboard/DashboardToolbar.tsx",
    "./dashboard/DashboardEmptyState": "./src/dashboard/DashboardEmptyState.tsx",
    "./dashboard/DashboardDropZone": "./src/dashboard/DashboardDropZone.tsx",
    "./dashboard/DashboardResizeHandle": "./src/dashboard/DashboardResizeHandle.tsx",
    "./dashboard/HandlePrimitive": "./src/dashboard/HandlePrimitive.tsx",
    "./dashboard/WidgetRegistry": "./src/dashboard/WidgetRegistry.ts",
    "./app-kit": "./src/app-kit/index.ts",
    "./app-kit/AppSidebar": "./src/app-kit/AppSidebar.tsx",
    "./app-kit/AppTopbar": "./src/app-kit/AppTopbar.tsx",
    "./app-kit/AppWidget": "./src/app-kit/AppWidget.tsx",
    "./app-kit/AppMetricStrip": "./src/app-kit/AppMetricStrip.tsx",
    "./app-kit/AppDashboardScreen": "./src/app-kit/AppDashboardScreen.tsx",
    "./app-kit/AppAIWorkspaceScreen": "./src/app-kit/AppAIWorkspaceScreen.tsx",
    "./app-kit/AppPluginsScreen": "./src/app-kit/AppPluginsScreen.tsx",
    "./app-kit/AppConnectorWizardScreen": "./src/app-kit/AppConnectorWizardScreen.tsx",
    "./app-kit/AppIconLibrary": "./src/app-kit/AppIconLibrary.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "recharts": "3.8.1",
    "typescript": "6.0.3"
  }
}
