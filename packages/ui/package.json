{
  "name": "@metraly/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/**/*.css"
  ],
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles/metraly-ui.css",
    "./styles/*": "./dist/styles/*",
    "./fonts/*": "./dist/fonts/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run clean && tsup src/index.ts --format esm,cjs --dts --out-dir dist --external react,react-dom,recharts && mkdir -p dist/styles dist/fonts && cp src/styles/*.css dist/styles/ && cp src/fonts/*.woff2 dist/fonts/"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "recharts": "3.8.1",
    "tsup": "^8.5.0",
    "typescript": "6.0.3"
  }
}
